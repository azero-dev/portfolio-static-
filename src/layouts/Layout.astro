---
// Import global styles
import '../styles/global.css';

import { ClientRouter } from 'astro:transitions';

// Import React components for theme management
import { ThemeToggle } from '@/components/layout/ThemeToggle';
import { Navigation } from '@/components/layout/Navigation';

// Import layout components
import Container from '@/components/layout/Container.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article' | 'profile';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  author?: string;
}

// Default values
const {
  title = 'Portfolio - Minimal Cyberpunk',
  description = 'Software engineer building web things. Portfolio and blog with cyberpunk aesthetic.',
  image = '/og-image.png',
  canonicalUrl = Astro.url.href,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  author = 'azer0',
} = Astro.props;

// Site metadata
const siteTitle = 'azer0 Portfolio';
const siteUrl = 'https://inferente.com';
const twitterHandle = '@azer0';


// Construct full title
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;

// Generate JSON-LD structured data
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${siteUrl}/#person`,
      name: 'azer0',
      url: siteUrl,
      description: 'Software engineer building web things. Portfolio and blog.',
      image: `${siteUrl}/avatar.png`,
      sameAs: [
        'https://github.com/azero-dev',
        'https://www.linkedin.com/in/franrodriguez1/',
      ],
    },
    type === 'article' ? {
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: `${siteUrl}${image}`,
      datePublished: publishedTime,
      dateModified: modifiedTime || publishedTime,
      author: {
        '@type': 'Person',
        name: author,
        url: `${siteUrl}/about`,
      },
      publisher: {
        '@type': 'Person',
        name: 'azer0',
        url: siteUrl,
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': canonicalUrl,
      },
      keywords: tags.join(', '),
    } : {
      '@type': 'WebSite',
      name: siteTitle,
      description,
      url: siteUrl,
      publisher: {
        '@type': 'Person',
        name: 'azer0',
      },
    },
  ].filter(Boolean),
};
---

<!doctype html>
<html lang="en" suppressHydrationWarning>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  
  <!-- Primary Meta Tags -->
  <title>{fullTitle}</title>
  <meta name="title" content={fullTitle} />
  <meta name="description" content={description} />
  <meta name="author" content={author} />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, siteUrl).href} />
  <meta property="og:site_name" content={siteTitle} />
  <meta property="og:locale" content="en_GB" />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  {tags.length > 0 && tags.map(tag => <meta property="article:tag" content={tag} />)}
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalUrl} />
  <meta property="twitter:title" content={fullTitle} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={new URL(image, siteUrl).href} />
  <meta property="twitter:creator" content={twitterHandle} />
  <meta property="twitter:site" content={twitterHandle} />
  
  
  <!-- Canonical URL -->
  <link rel="canonical" href={canonicalUrl} />
  
  <!-- RSS Feeds -->
  <link rel="alternate" type="application/rss+xml" href="/feed.rss" title={`RSS Feed - ${siteTitle}`} />
  <link rel="alternate" type="application/atom+xml" href="/atom.xml" title={`Atom Feed - ${siteTitle}`} />
  
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd, null, 2)} />

  <!-- ViewTransitions for smooth page routing -->
  <ClientRouter />

  <!-- Inline Theme Script to prevent FOUC -->
  <script is:inline>
    const setTheme = () => {
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
    
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      
      window.localStorage.setItem('theme', theme);
    };

    setTheme();
    document.addEventListener('astro:after-swap', setTheme);
  </script>
</head>
<body class="min-h-screen font-sans antialiased">
  <Container as="div" className="min-h-screen">
    <header class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur supports-[backdrop-filter]:bg-background/60" data-pagefind-ignore>
        <Container as="div" className="flex h-16 items-center justify-between">
          <div class="flex items-center gap-2">
            <a href="/" class="font-mono text-xl font-bold tracking-tighter text-primary hover:opacity-80 transition-opacity">
              &gt;portfolio_
            </a>
          </div>
        <div class="flex items-center gap-4">
          <Navigation client:only="react" />
          <ThemeToggle client:only="react" />
        </div>
      </Container>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-auto border-t border-border py-8" data-pagefind-ignore>
        <Container>
          <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
            <div class="font-mono text-sm text-muted-foreground">
              &copy; {new Date().getFullYear()} Portfolio. Built with Astro.
            </div>
            <div class="flex items-center gap-4">
              <a href="https://github.com/azero-dev" target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-muted-foreground hover:text-primary">
                GitHub
              </a>
              <a href="https://www.linkedin.com/in/franrodriguez1/" target="_blank" rel="noopener noreferrer" class="font-mono text-sm text-muted-foreground hover:text-primary">
                LinkedIn
              </a>
            </div>
          </div>
        </Container>
      </footer>
  </Container>
</body>
</html>

<style>
  /* Ensure smooth scrolling */
  html {
    scroll-behavior: smooth;
  }
</style>
