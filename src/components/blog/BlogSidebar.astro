---
import { getCollection } from 'astro:content';
import { SearchBar } from './SearchBar';
import { TagsCloud } from './TagsCloud';

interface Props {
  activeTag?: string;
}

const { activeTag } = Astro.props;

// Get all posts to extract tags
const posts = await getCollection('blog', ({ data }) => !data.draft);

// Count tag frequency
const tagCounts: Record<string, number> = {};
posts.forEach((post) => {
  post.data.tags.forEach((tag) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});

// Convert to array and sort by frequency
const allTags = Object.entries(tagCounts)
  .map(([tag, count]) => ({ tag, count }))
  .sort((a, b) => b.count - a.count);

const maxCount = allTags.length > 0 ? Math.max(...allTags.map(t => t.count)) : 1;
---

<div class="space-y-8">
  {/* Search */}
  <div>
    <h3 class="font-mono text-lg font-bold mb-4">&gt;search</h3>
    <SearchBar client:load />
  </div>

  {/* Tags cloud */}
  {allTags.length > 0 && (
    <TagsCloud client:load tags={allTags} activeTag={activeTag} maxCount={maxCount} />
  )}

  {/* Recent posts */}
  {posts.length > 0 && (
    <div>
      <h3 class="font-mono text-lg font-bold mb-4">&gt;recent</h3>
      <ul class="space-y-3">
        {posts
          .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
          .slice(0, 5)
          .map((post) => (
             <li>
              <a
                href={`/post/${post.id}`}
                class="group block p-3 rounded-md border border-border hover:border-primary transition-colors"
              >
                <h4 class="font-semibold text-foreground group-hover:text-primary transition-colors line-clamp-1">
                  {post.data.title}
                </h4>
                <p class="text-xs text-muted-foreground mt-1">
                  {new Date(post.data.pubDate).toLocaleDateString('en-GB', {
                    day: 'numeric',
                    month: 'short',
                    year: 'numeric'
                  })}
                </p>
              </a>
            </li>
          ))}
      </ul>
    </div>
  )}
</div>