---
import Layout from '../layouts/Layout.astro';
import Container from '../components/layout/Container.astro';
import Section from '../components/layout/Section.astro';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';


// Import data
import projects from '../data/projects.json';
import experience from '../data/experience.json';
import education from '../data/education.json';
import skills from '../data/skills.json';
import { ProjectsTabs } from '@/components/about/ProjectsTabs';

export const prerender = true;

// Filter projects by status
const activeProjects = projects.filter(p => p.status === 'active');
const archivedProjects = projects.filter(p => p.status === 'archived');

// SEO metadata
const title = 'About';
const description = 'Software Engineer & Cyberpunk enthusiast building the future with code. Portfolio with experience, projects, and contact.';
const canonicalUrl = Astro.url.href;
---

<Layout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  type="profile"
>
  <Section padding="xl">
    <Container>
      {/* Hero section */}
      <div class="text-center mb-16">
        <h1 class="font-mono text-4xl md:text-5xl font-bold tracking-tighter mb-4">
          &gt;about_
        </h1>
        <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
          Software Engineer & Cyberpunk enthusiast building the future with code.
        </p>
      </div>

      {/* Intro section */}
      <Section padding="lg">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="font-mono text-2xl font-bold mb-6">&gt;who_am_i</h2>
          <p class="text-lg text-muted-foreground">
            Welcome to my digital corner. I'm a passionate developer with a love for minimalist design, cutting-edge technology, and the cyberpunk aesthetic. This portfolio is a reflection of my journey—where code meets creativity.
          </p>
        </div>
      </Section>

      {/* Three horizontal blocks */}
      <Section padding="lg">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Experience -->
          <Card className="border-border">
            <CardHeader>
              <CardTitle className="font-mono">&gt;experience</CardTitle>
              <CardDescription>Professional journey</CardDescription>
            </CardHeader>
            <CardContent>
              <ul class="space-y-4">
                {experience.slice(0, 3).map((item) => (
                  <li>
                    <h3 class="font-semibold">{item.role}</h3>
                    <p class="text-sm text-muted-foreground">{item.company} • {item.period}</p>
                    <p class="text-sm mt-1">{item.description}</p>
                  </li>
                ))}
              </ul>
            </CardContent>
          </Card>

          <!-- Education -->
          <Card className="border-border">
            <CardHeader>
              <CardTitle className="font-mono">&gt;education</CardTitle>
              <CardDescription>Academic background</CardDescription>
            </CardHeader>
            <CardContent>
              <ul class="space-y-4">
                {education.map((item) => (
                  <li>
                    <h3 class="font-semibold">{item.degree}</h3>
                    <p class="text-sm text-muted-foreground">{item.institution} • {item.period}</p>
                    <p class="text-sm mt-1">{item.description}</p>
                  </li>
                ))}
              </ul>
            </CardContent>
          </Card>

          <!-- Skills -->
          <Card className="border-border">
            <CardHeader>
              <CardTitle className="font-mono">&gt;skills</CardTitle>
              <CardDescription>Technologies & tools</CardDescription>
            </CardHeader>
            <CardContent>
                <div class="flex flex-wrap gap-2">
                  {skills.flatMap(category => category.items).map((skill) => (
                    // @ts-ignore
                    <Badge key={skill} variant="secondary" className="font-mono text-xs">
                      {skill}
                    </Badge>
                  ))}
                </div>
            </CardContent>
          </Card>
        </div>
      </Section>

      {/* Projects: Active */}
      <Section padding="lg">
        <h2 class="font-mono text-2xl font-bold mb-8 text-center">&gt;active_projects</h2>
         <ProjectsTabs activeProjects={activeProjects} archivedProjects={archivedProjects} client:load />
      </Section>

      {/* Contact form */}
      <Section padding="lg">
        <div class="max-w-2xl mx-auto">
          <h2 class="font-mono text-2xl font-bold mb-8 text-center">&gt;get_in_touch</h2>
          <Card className="border-border">
            <CardHeader>
              <CardTitle className="font-mono">Contact Form</CardTitle>
              <CardDescription>Send me a message directly via email</CardDescription>
            </CardHeader>
            <CardContent>
              <form id="contact-form" action="#" method="post" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label for="name" class="block text-sm font-medium mb-1">Name</label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      class="w-full px-3 py-2 border border-input rounded-md bg-background text-foreground"
                      placeholder="Your name"
                    />
                  </div>
                  <div>
                    <label for="email" class="block text-sm font-medium mb-1">Email</label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      class="w-full px-3 py-2 border border-input rounded-md bg-background text-foreground"
                      placeholder="your.email@example.com"
                    />
                  </div>
                </div>
                <div>
                  <label for="message" class="block text-sm font-medium mb-1">Message</label>
                  <textarea
                    id="message"
                    name="message"
                    rows="4"
                    required
                    class="w-full px-3 py-2 border border-input rounded-md bg-background text-foreground"
                    placeholder="Your message here..."
                  ></textarea>
                </div>
                <div class="flex justify-end">
                  <Button type="submit" className="font-mono">
                    Send Message
                  </Button>
                </div>
              </form>
            </CardContent>
          </Card>
        </div>
      </Section>
    </Container>
  </Section>
</Layout>

<script>
  // Simple form validation and mailto fallback
  const form = document.getElementById('contact-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const nameInput = document.getElementById('name') as HTMLInputElement;
      const emailInput = document.getElementById('email') as HTMLInputElement;
      const messageInput = document.getElementById('message') as HTMLTextAreaElement;
      
      const name = nameInput.value.trim();
      const email = emailInput.value.trim();
      const message = messageInput.value.trim();
      
      // Validation
      if (!name || name.length < 2) {
        alert('Please enter a valid name (at least 2 characters).');
        nameInput.focus();
        return;
      }
      
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        alert('Please enter a valid email address.');
        emailInput.focus();
        return;
      }
      
      if (!message || message.length < 10) {
        alert('Please enter a message (at least 10 characters).');
        messageInput.focus();
        return;
      }
      
      // Construct mailto link
      const subject = `Contact from ${name}`;
      const bodyText = `Name: ${name}\nEmail: ${email}\n\n${message}`;
      const encodedBody = encodeURIComponent(bodyText);
      const encodedEmail = 'ZnIucm9kbWFyQHByb3Rvbi5tZQ==';
      
      window.location.href = `mailto:${atob(encodedEmail)}?subject=${encodeURIComponent(subject)}&body=${encodedBody}`;
    });
  }
</script>