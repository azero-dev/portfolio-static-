---
import Layout from '../../../layouts/Layout.astro';
import Container from '../../../components/layout/Container.astro';
import Section from '../../../components/layout/Section.astro';
import BlogSidebar from '../../../components/blog/BlogSidebar.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  
  // Extract all unique tags
  const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags))];

  return allTags.flatMap((tag) => {
    const filteredPosts = allPosts.filter((post) => post.data.tags.includes(tag));
    filteredPosts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
    
    return paginate(filteredPosts, {
      params: { tag },
      pageSize: 15
    });
  });
}

const { page } = Astro.props;
const { tag } = Astro.params;

// SEO metadata
const title = `Blog - ${tag} - Page ${page.currentPage}`;
const description = `Page ${page.currentPage} of blog posts tagged "${tag}"`;
const canonicalUrl = Astro.url.href;
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <Section padding="xl">
    <Container>
      <div class="text-center mb-12">
        <h1 class="font-mono text-4xl md:text-5xl font-bold tracking-tighter mb-4">
          &gt;blog_{tag}_
        </h1>
        <p class="text-xl text-muted-foreground max-w-2xl mx-auto">
          Posts tagged with "{tag}" (Page {page.currentPage} of {page.lastPage})
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {/* Main content - Blog posts */}
        <div class="lg:col-span-2">
          {page.data.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {page.data.map((post) => (
                <div class="border border-border rounded-lg p-4 hover:border-primary transition-colors h-full flex flex-col">
                  <h2 class="font-mono text-lg font-bold mb-2">{post.data.title}</h2>
                  <p class="text-sm text-muted-foreground mb-3">
                    {new Date(post.data.pubDate).toLocaleDateString('en-GB', {
                      day: 'numeric',
                      month: 'short',
                      year: 'numeric'
                    })}
                  </p>
                  <p class="text-sm text-foreground mb-4 flex-grow">{post.data.description}</p>
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.data.tags.slice(0, 3).map((t) => (
                      <span class="text-xs font-mono px-2 py-1 border border-border rounded">
                        {t}
                      </span>
                    ))}
                  </div>
                  <a
                    href={`/post/${post.id}`}
                    class="font-mono text-sm text-primary hover:underline mt-auto"
                  >
                    Read Post →
                  </a>
                </div>
              ))}
            </div>
          ) : (
            <div class="text-center py-12">
              <p class="text-muted-foreground font-mono">No posts found.</p>
            </div>
          )}
        </div>

        {/* Sidebar */}
        <div class="lg:col-span-1">
          <div class="sticky top-24">
              <BlogSidebar activeTag={tag} />
          </div>
        </div>
      </div>

      {/* Pagination */}
      {(page.url.prev || page.url.next) && (
        <Section padding="md">
          <div class="flex justify-center items-center gap-8">
            {page.url.prev && (
              <a
                href={page.url.prev}
                class="font-mono text-sm text-primary hover:underline flex items-center gap-2"
              >
                ← Previous Page
              </a>
            )}
            <span class="font-mono text-sm text-muted-foreground">
              Page {page.currentPage} of {page.lastPage}
            </span>
            {page.url.next && (
              <a
                href={page.url.next}
                class="font-mono text-sm text-primary hover:underline flex items-center gap-2"
              >
                Next Page →
              </a>
            )}
          </div>
        </Section>
      )}
    </Container>
  </Section>
</Layout>
