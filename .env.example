# Environment Variables Example
# Copy this file to `.env` for local development.
# For production, set these in Cloudflare Pages > Settings > Environment variables.

# Cloudflare Analytics (public)
PUBLIC_CF_ANALYTICS_TOKEN=your_analytics_token_here

# ActivityPub (server-side, only needed for sync endpoint and Fedify)
# These are used in Cloudflare Functions; they are not exposed to the client.
SYNC_TOKEN=your_sync_secret_token_here
FEDIFY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
... your private key PEM ...
-----END RSA PRIVATE KEY-----
# Optional: if you want to provide the public key explicitly
# FEDIFY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
# ... your public key PEM ...
# -----END PUBLIC KEY-----

# Cloudflare Bindings (configured in wrangler.toml)
# DB binding: D1 database
# KV binding: Key-Value store
# STATIC_ASSETS binding: Static files
# IMAGES binding: Cloudflare Images

# Note: For local development with D1/KV, use `wrangler dev` and
# set the database_id and preview_id in wrangler.toml.